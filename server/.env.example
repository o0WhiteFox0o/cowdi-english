# ── Google OAuth (bắt buộc) ─────────────────────────────────────────────────
# Lấy từ: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# URL callback phải khớp CHÍNH XÁC với Authorized redirect URIs trong Google Console
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ── JWT ────────────────────────────────────────────────────────────────────
# Chuỗi bí mật ngẫu nhiên, ít nhất 32 ký tự
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── MySQL ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cowdi_english

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
# URL frontend (dùng cho CORS và redirect sau login)
FRONTEND_URL=http://localhost:5173

# ── Session (chỉ dùng trong quá trình OAuth dance, không lưu lâu dài) ─────
SESSION_SECRET=another_random_secret_for_session
